<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>CS1573;CS1591</NoWarn>

    <!-- NuGet package metadata -->
    <PackageId>Remit</PackageId>
    <PackageProjectUrl>https://pay-skill.com</PackageProjectUrl>
    <Version>0.4.0</Version>
    <Authors>remit-md</Authors>
    <Description>DEPRECATED: Use pay-cli or pay SDKs instead. See https://pay-skill.com/docs</Description>
    <RepositoryUrl>https://github.com/remit-md/pay-sdk</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>payments;usdc;agents;ai;ethereum;base;stablecoin;remitmd;mcp</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>RemitMd.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <!-- EIP-712 signing + secp256k1 ECDSA via Nethereum (lightweight signer only) -->
    <PackageReference Include="Nethereum.Signer" Version="4.21.0" />
    <!-- Semantic Kernel integration (optional — no hard dep, uses conditional compile) -->
    <PackageReference Include="Microsoft.SemanticKernel.Core" Version="1.21.1" Condition="'$(IncludeSemanticKernel)' == 'true'" />
  </ItemGroup>

  <!-- Exclude Semantic Kernel plugin when the package isn't included -->
  <ItemGroup Condition="'$(IncludeSemanticKernel)' != 'true'">
    <Compile Remove="SemanticKernel\**" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
