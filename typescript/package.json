{
  "name": "@remitmd/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the remit.md universal AI payment protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
